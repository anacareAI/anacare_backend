# ── Tuning (optional — defaults are fine) ─────────────────────────
# How many hospital files to stream simultaneously
LAYER1_CONCURRENCY=8

# How many UHC files to stream simultaneously
LAYER2_CONCURRENCY=3

# DB write batch size (rows per INSERT)
DB_BATCH=200

# Skip hospitals scraped within N days (for resume/incremental runs)
SKIP_SCRAPED_DAYS=30

# 0 = all hospitals. Set to 10 for a quick test run.
LAYER1_LIMIT=0

# Max UHC negotiated rate rows to ingest (0 = unlimited)
LAYER2_MAX_ROWS=5000000

# Max BCBS in-network files to process per state plan
BCBS_MAX_FILES=10

# Where logs are written
LOG_DIR=./logs
